JELLYRIN_HOST=0.0.0.0
JELLYRIN_PORT=8096
JELLYRIN_DATA_DIR=/var/lib/jellyrin
JELLYRIN_CONFIG_DIR=/etc/jellyrin
JELLYRIN_CACHE_DIR=/var/cache/jellyrin
